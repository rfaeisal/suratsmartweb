# Database
DATABASE_URL=postgresql://cutismart:cutismart_dev@localhost:5434/cutismart
POSTGRES_PASSWORD=cutismart_dev

# NextAuth (generate dengan: openssl rand -base64 32)
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Integrasi Sistem Lama (PHP)
# Set LEGACY_SSO_MOCK=true untuk development sebelum sistem lama siap
LEGACY_SSO_MOCK=true
LEGACY_API_BASE_URL=http://simpeg.internal/api
LEGACY_API_KEY=your-api-key-here
LEGACY_API_HMAC_SECRET=your-hmac-secret-here

# Firebase (untuk push notification FCM)
# Isi dengan JSON service account dari Firebase Console
FIREBASE_SERVICE_ACCOUNT_JSON=

# Penyimpanan file lampiran & SK PDF
# STORAGE_PROVIDER=local         → simpan di filesystem (on-premise Docker)
# STORAGE_PROVIDER=vercel-blob   → simpan di Vercel Blob (untuk deploy di Vercel)
STORAGE_PROVIDER=local
FILE_STORAGE_PATH=./uploads

# Vercel Blob (hanya dibutuhkan jika STORAGE_PROVIDER=vercel-blob)
# Dapatkan token dari: Vercel Dashboard → Storage → Blob → Token
BLOB_READ_WRITE_TOKEN=

# Neon / Vercel Postgres (hanya dibutuhkan saat deploy di Vercel)
# DATABASE_URL      → pooled connection string (untuk queries)
# DIRECT_URL        → direct connection string (untuk prisma migrate deploy)
# DIRECT_URL=postgresql://...
